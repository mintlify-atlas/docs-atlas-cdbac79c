  "keyFeatures": [
    "Annotation-based filter definitions with @QFDefinitionClass and @QFElement",
    "RHS Colon (field=eq:value) and LHS Brackets (field[eq]=value) syntax support",
    "Automatic OpenAPI/Swagger documentation generation",
    "PostgreSQL array and JSON field filtering",
    "Sorting with multiple fields and directions",
    "Custom predicates with SpEL expressions",
    "Collection size filtering operations",
    "Support for both Spring Boot 3 and Spring Boot 4",
    "Seamless integration with JpaSpecificationExecutor",
    "@QFMultiParam for binding multiple filter parameters"
  ],
  "publicApiSurface": [
